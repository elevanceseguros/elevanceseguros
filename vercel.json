{
  "installCommand": "npm install --legacy-peer-deps",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "elevanceseguros.com" }],
      "destination": "https://www.elevanceseguros.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
